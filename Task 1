#include <stdio.h>     

long long fact(int n)
{
    if(n == 1) return 1;
    return n * fact(n - 1);
}

double b(int k);  

double a(int k)
{
    if(k == 1) return 1;
    return 0.3 * b(k - 1) + 0.2 * a(k - 1);
}

double b(int k)
{
    if(k == 1) return 1;
    return a(k - 1)*a(k - 1) + b(k - 1)*b(k - 1);
}

double sum(int n)
{
    if(n == 1)
        return a(1)*b(1) / fact(2);

    return sum(n - 1) + a(n)*b(n) / fact(n + 1);
}

int main()
{
    int n;
    printf("n = ");
    scanf("%d", &n);

    printf("S = %lf\n", sum(n));

    return 0;
}
